# Copy to .env and fill in (never commit .env)

PORT=3000
# Bind all interfaces so phones on the same Wi‑Fi can reach the API (use with npm run dev:lan on static site).
LISTEN_HOST=0.0.0.0
# Windows/proxy TLS fix for outbound HTTPS (Supabase, etc.).
# NODE_OPTIONS=--use-system-ca
# If your company proxy uses a custom root CA, also set:
# NODE_EXTRA_CA_CERTS=C:\path\to\company-root-ca.pem

# Supabase (server keys — keep secret; not for the browser)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# JWT is issued by Supabase Auth; server uses anon + service clients from config/supabase.js

# CORS: browser origins allowed to call this API (your Netlify/Vercel site(s))
FRONTEND_URL=http://localhost:5500
FRONTEND_URL_PROD=
# Optional comma-separated list for previews / extra hosts (e.g. https://branch--site.netlify.app)
CORS_ORIGINS=

# Auth brute-force protection (/api/auth/*)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Route-specific abuse protection
PUBLIC_READ_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_READ_RATE_LIMIT_MAX=600
WRITE_RATE_LIMIT_WINDOW_MS=900000
WRITE_RATE_LIMIT_MAX=120
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX=60

# Public GET response cache (server memory)
PUBLIC_READ_CACHE_TTL_SECONDS=30
PUBLIC_READ_CACHE_MAX_ENTRIES=500
