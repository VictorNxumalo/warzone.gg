{
  "_document": "Mock data + UI field map for creating matches under tournament \"FIFA Winter Cup 2026 — Mock\". Pair with fifa-admin-mock-walkthrough.json.",
  "how_admin_match_create_works": {
    "source": "pages/admin.html",
    "navigation": [
      "Sign in as admin → open Admin panel.",
      "Sidebar: open tab **Matches**.",
      "Click **Create Match For Tournament** (not Update)."
    ],
    "dropdown_logic": {
      "game_select_id": "match-game",
      "tournament_select_id": "match-tourney-id",
      "filtering": "After you choose a Game, the Tournament list shows only tournaments where inferTournamentGame(t) equals that game. For FIFA, tournament name OR mode OR type must contain the substring 'fifa' (case-insensitive). Example: name 'FIFA Winter Cup 2026 — Mock' matches.",
      "teams_source": "Team A / Team B options come from GET registrations with tournament_id = selected tournament and status = **approved** only. If empty, approve registrations under Participants tab first."
    },
    "fields_created_match": [
      { "html_id": "match-game", "sent_to_api": "Used only client-side for filtering; not sent." },
      { "html_id": "match-tourney-id", "api_field": "tournament_id", "required": true },
      { "html_id": "match-a-id", "api_field": "team_a_id", "required": true },
      { "html_id": "match-b-id", "api_field": "team_b_id", "optional": "Empty → null (bye / TBD)" },
      { "html_id": "match-round", "api_field": "round", "values": ["group_stage", "quarter_final", "semi_final", "grand_final"] },
      { "html_id": "match-scheduled-at", "api_field": "scheduled_at", "note": "Browser datetime-local; empty → null" },
      { "html_id": "score-a", "api_field": "Not sent on create", "note": "Create flow always sends score_a/score_b as null. If user types scores, UI clears them and shows toast — enter results under Update sub-tab." },
      { "html_id": "match-map", "api_field": "map_name" },
      { "html_id": "match-mode", "api_field": "game_mode" }
    ],
    "api_payload_on_save": {
      "function": "handleSubmitMatch → submitMatch() → POST /api/matches",
      "fixed_shape": {
        "tournament_id": "<uuid from match-tourney-id>",
        "team_a_id": "<uuid>",
        "team_b_id": "<uuid or null>",
        "score_a": null,
        "score_b": null,
        "round": "<from match-round>",
        "map_name": "<string or empty>",
        "game_mode": "<string or empty>",
        "status": "scheduled",
        "scheduled_at": "<ISO string or null>"
      }
    }
  },
